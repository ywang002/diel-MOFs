units real 
dimension 3
boundary p p p
atom_style full
box tilt   large
timestep 0.25

# processors 4 4 4
############          force field setting        ############
bond_style      harmonic
angle_style     cosine/periodic
dihedral_style  harmonic
improper_style  fourier
pair_style      lj/cut/coul/long 12.5
pair_modify     tail yes mix arithmetic 

special_bonds   lj/coul 0.0 0.0 1.0
kspace_style    ewald 1e-6
# kspace_modify gewald 0.5
read_data pristine.data
neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes
thermo_style custom step temp press vol ke pe
############          energy minimization        ############

# GEO/CELL OPT
label           loop
variable        a loop 50

print           "------> GEO OPT Run ${a}"
min_style       cg
min_modify      line quadratic dmax 0.1
minimize        1.0e-10 1.0e-10 1000 10000

print           "------> CELL OPT Run ${a}"
fix             cell all box/relax tri 1.0 vmax 0.001
min_style       cg
min_modify      line quadratic dmax 0.1
minimize        1.0e-10 1.0e-10 1000 10000
unfix           cell

next            a
jump            opt.in loop
label           break
variable        a delete

